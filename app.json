{
  "expo": {
    "name": "FitProgress",
    "slug": "fitprogress",
    "owner": "dtug21",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "fitprogress",
    "userInterfaceStyle": "dark",
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png",
      "name": "FitProgress",
      "shortName": "FitProgress",
      "lang": "es",
      "backgroundColor": "#0B0B0C",
      "themeColor": "#0B0B0C",
      "display": "standalone",
      "orientation": "portrait",
      "description": "Tu app de entrenamiento con progresión inteligente",
      "preferRelatedApplications": false
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "resizeMode": "contain",
          "backgroundColor": "#0B0B0C"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "baseUrl": "/fitprogress"
    }
  }
}
