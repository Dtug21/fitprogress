{
  "expo": {
    "name": "FitProgress",
    "slug": "fitprogress",
    "owner": "dtug21",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "fitprogress",
    "userInterfaceStyle": "dark",
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png",
      "name": "FitProgress",
      "shortName": "FitProgress",
      "lang": "es",
      "backgroundColor": "#0B0B0C",
      "themeColor": "#C6F24E",
      "description": "Tu app de entrenamiento con progresión inteligente",
      "preferRelatedApplications": false
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "resizeMode": "contain",
          "backgroundColor": "#ffffff"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "419f9fc3-63f8-468a-bb3b-32cc9253a7b0"
      }
    },
    "runtimeVersion": {
      "policy": "sdkVersion"
    },

    "updates": {
      "url": "https://u.expo.dev/419f9fc3-63f8-468a-bb3b-32cc9253a7b0"
    }
  }
}
